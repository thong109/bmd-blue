  footer.footer-common#footer-contact
    .wrapper
      .footer-wrapper.js-title
        .footer-common-information
          a(href=path+"/").footer-logo.trans
            img.image-common(src=imgCommonPC+"logo_primary.svg" width="133" height="76" alt="The emerald boulevard" loading="lazy")
          ul.information-list
            li.list-item
              p.item-title Sales Office:
              address Số 68 Đại lộ Bình Dương – Khu phố Tây – P. Lái Thiêu – TP. Hồ Chí Minh
            li.list-item
              p.item-title SaleS Gallary:
              address Số 68 Đại lộ Bình Dương – Khu phố Tây – P. Lái Thiêu – TP. Hồ Chí Minh
            li.list-item
              p.item-title HOTLINE:
              a(href="tel:+19002663").item-phone.trans 19002663
            li.list-item
              p.item-title EMAIL: 
                a(href="mailto:theemeraldboulevardofficial@gmail.com").trans theemeraldboulevardofficial@gmail.com
          ul.socials-list
            li.list-item
              a.item-wrapper.trans(href="#" target="_blank" rel="noopener")

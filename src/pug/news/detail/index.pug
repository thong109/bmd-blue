extends ../../_base/_layout.pug
block vars
  - var metaTitle = 'News Detail'
  - var path = '../..'
  - var page = 'new'
  - var imgPC = path + '/resources/images/new/'
  - var imgSP = path + '/resources/images/new/sp/'
  - var imgCommonPC = path + '/resources/images/common/'
  - var imgCommonSP = path + '/resources/images/common/sp/'

block content
  section.section-new-article
    .wrapper
      .article-wrapper
        h1.article-title Lộ diện dự án cao cấp của <br>Tập đoàn Lê Phong
        time.article-date 03.02.2026
        .post-content
          p
            strong Sau chuỗi dự án ghi dấu ấn trên thị trường, Tập đoàn Lê Phong tiếp tục giới thiệu dự án cao cấp The Emerald Boulevard tại mặt tiền Quốc lộ 13 – trục giao thông huyết mạch cửa ngõ Đông Bắc TP.HCM.
          h2 Chiến lược phát triển nhất quán của Tập đoàn Lê Phong
          p Trong bối cảnh thị trường bất động sản ngày càng sàng lọc khắt khe, các tiêu chí như pháp lý minh bạch, chất lượng xây dựng và tiến độ triển khai trở thành yếu tố quyết định niềm tin của người mua. Tập đoàn Lê Phong là một trong những doanh nghiệp theo đuổi chiến lược phát triển dài hạn, tập trung vào việc kiến tạo sản phẩm có giá trị sử dụng thực và khả năng khai thác bền vững.
          figure
            img(src=imgPC+"news_img_04.jpg" alt="The Emerald Boulevard")
            figcaption Ông Bùi Ngươn Phong – Chủ tịch HĐQT – Nhà sáng lập hệ sinh thái Tập đoàn Lê Phong phát biểu tại sự kiện ký kết hợp tác chiến lược dự án The Emerald Boulevard.
          p Theo đại diện doanh nghiệp, mỗi dự án của Tập đoàn Lê Phong đều được chuẩn bị kỹ lưỡng ngay từ giai đoạn quy hoạch, thiết kế cho đến lựa chọn các đối tác thi công, giám sát. Cách tiếp cận này giúp đảm bảo tính đồng bộ trong triển khai, kiểm soát chất lượng công trình và hạn chế rủi ro phát sinh, đặc biệt trong bối cảnh thị trường biến động.
          figure
            img(src=imgPC+"news_img_05.jpg" alt="The Emerald Boulevard")
            figcaption Lễ khởi công dự án The Emerald Boulevard.
          p Dự án được phát triển trên quỹ đất hơn 10.000m², gồm 3 tòa tháp cao 40 tầng và 3 tầng hầm, hình thành một quần thể kiến trúc hiện đại trên trục giao thông chiến lược. Danh mục sản phẩm đa dạng, bao gồm căn hộ từ 1 đến 3 phòng ngủ, penthouse, shophouse và condotel, được thiết kế theo hướng tối ưu công năng, phù hợp với nhiều nhóm khách hàng từ gia đình trẻ, chuyên gia làm việc tại các khu công nghiệp lân cận đến nhà đầu tư dài hạn.
        .article-controller
          p Chia sẻ:
          .controller-list
            a(href="#").list-item.trans
              img.object-common(src=imgCommonPC+"social_icon_04.svg" width="60" height="60" loading="lazy" alt="Facebook")
            a(href="#").list-item.trans
              img.object-common(src=imgCommonPC+"social_icon_05.svg" width="60" height="60" loading="lazy" alt="Zalo")
  section.section-news-related
    .wrapper
      h2.hero-title.is-center.js-fadein
        span.title-sub
          span.sub-small TIN liên quan
      .list-top-news.js-fadein
        ul.list-wrapper
          li.list-item
            a(href=path+"/news/detail/").item-wrapper
              .item-image
                img.object-common(src=imgCommonPC+"news_img_01.jpg" width="754" height="410" loading="lazy" alt="Lộ diện dự án cao cấp của Tập đoàn Lê Phong")
              .item-content
                time.content-time
                  span.time-date 18
                  span.time-year 04.2026
                h3.content-title Lộ diện dự án cao cấp của Tập đoàn Lê Phong
          li.list-item
            a(href=path+"/news/detail/").item-wrapper
              .item-image
                img.object-common(src=imgCommonPC+"news_img_02.jpg" width="450" height="244" loading="lazy" alt="Mặt tiền QL 13 có thêm dự án cao cấp The Emerald Boule-vard")
              .item-content
                time.content-time
                  span.time-date 13
                  span.time-year 04.2026
                h3.content-title Mặt tiền QL 13 có thêm dự án cao cấp The Emerald Boule-vard
          li.list-item
            a(href=path+"/news/detail/").item-wrapper
              .item-image
                img.object-common(src=imgCommonPC+"news_img_03.jpg" width="450" height="244" loading="lazy" alt="Khởi công dự án The Emerald Boulevard tại mặt tiền Quốc lộ 13")
              .item-content
                time.content-time
                  span.time-date 12
                  span.time-year 04.2026
                h3.content-title Khởi công dự án The Emerald Boulevard tại mặt tiền Quốc lộ 13
  footer.footer-common#footer-contact
    .wrapper
      .footer-wrapper.js-title
        .footer-common-information
          a(href=path+"/").footer-logo.trans
            img.image-common(src=imgCommonPC+"logo_primary.svg" width="133" height="76" alt="The emerald boulevard" loading="lazy")
          ul.information-list
            li.list-item
              p.item-title Sales Office:
              address Số 68 Đại lộ Bình Dương – Khu phố Tây – P. Lái Thiêu – TP. Hồ Chí Minh
            li.list-item
              p.item-title SaleS Gallary:
              address Số 68 Đại lộ Bình Dương – Khu phố Tây – P. Lái Thiêu – TP. Hồ Chí Minh
            li.list-item
              p.item-title HOTLINE:
              a(href="tel:+19002663").item-phone.trans 19002663
            li.list-item
              p.item-title EMAIL: 
                a(href="mailto:theemeraldboulevardofficial@gmail.com").trans theemeraldboulevardofficial@gmail.com
          ul.socials-list
            li.list-item
              a.item-wrapper.trans(href="#" target="_blank" rel="noopener")
                img.object-common(src=imgCommonPC+"social_icon_03.svg" width="67" height="67" loading="lazy" alt="Facebook")
            li.list-item
              a.item-wrapper.trans(href="#" target="_blank" rel="noopener")
                img.object-common(src=imgCommonPC+"social_icon_02.svg" width="67" height="67" loading="lazy" alt="Youtube")
            li.list-item
              a.item-wrapper.trans(href="#" target="_blank" rel="noopener")
                img.object-common(src=imgCommonPC+"social_icon_01.svg" width="67" height="67" loading="lazy" alt="Tiktok")
        .footer-common-contact
          p.contact-title ĐĂNG KÝ TƯ VẤN
          form.contact-form
            .form-group
              .group-input
                input.input-common(type="text" placeholder="HỌ TÊN *" required)
              .group-input
                input.input-common(type="text" placeholder="ĐIỆN THOẠI *" required)
            .form-group
              input.input-common(type="text" placeholder="EMAIL")
            .form-group
              textarea.textarea-common(placeholder="LỜI NHẮN")
            .form-controller
              button(type="submit").button-contact GỬI ĐĂNG KÝ
      .footer-navigation
        small 2026 &copy; THE EMERALD BOULEVARD. <span>ALL RIGHTS RESERVED</span>
        .navigation-list
          a.list-item.trans(href="#") Chính sách bảo mật
          a.list-item.trans(href="#") điều khoản chung
      p.footer-note <span>Lưu ý:</span> Hình ảnh mang tính chất minh họa. Chủ đầu tư có quyền thay đổi những thông tin,<br> hình ảnh liên quan đến dự án ở tài liệu này hoặc bất kỳ những phát sinh nào theo yêu cầu của cơ quan nhà nước có thẩm quyền.
